<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Android" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorError">@color/error</item>
    </style>

    <style name="ThemeOverlay.Android.FullscreenContainer" parent="">
        <item name="fullscreenBackgroundColor">@color/primary_dark</item>
        <item name="fullscreenTextColor">@color/primary_light</item>
    </style>
</resources>